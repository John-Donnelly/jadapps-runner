{
  "name": "@jadapps/runner",
  "version": "0.1.0",
  "description": "Local execution runtime for JAD Apps. Native file processing, credential-scoped connectors, JWT-authenticated workflow execution.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "jadapps-runner": "./dist/cli.js"
  },
  "main": "./dist/runner.js",
  "types": "./dist/runner.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "tauri": "tauri",
    "tauri:dev": "npm run build && tauri dev",
    "tauri:build": "npm run build && tauri build"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^0.1.100",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "docx": "^9.0.2",
    "exceljs": "^4.4.0",
    "exifr": "^7.1.3",
    "fastify": "^5.0.0",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "marked": "^14.1.3",
    "mongodb": "^6.10.0",
    "nodemailer": "^6.9.16",
    "openpgp": "^5.11.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "redis": "^4.7.0",
    "undici": "^7.0.0",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "playwright": "^1.48.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
